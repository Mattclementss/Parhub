# ─────────────────────────────────────────────────────────────────────────────
# ParHub — required environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
# Full URL of the deployed app (used for WHOOP OAuth redirect_uri)
# Dev:  http://localhost:3000
# Prod: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ── WHOOP OAuth ───────────────────────────────────────────────────────────────
# Found in: https://developer.whoop.com → your application
# Client ID is intentionally public (used in OAuth redirect URL)
NEXT_PUBLIC_WHOOP_CLIENT_ID=your_whoop_client_id
# Client secret is SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_
WHOOP_CLIENT_SECRET=your_whoop_client_secret

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
# Found in: https://console.anthropic.com → API keys
# SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_
ANTHROPIC_API_KEY=sk-ant-...

# ── Golf Course API ───────────────────────────────────────────────────────────
# Found in: https://golfcourseapi.com → your account
# SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_
GOLF_COURSE_API_KEY=your_golf_course_api_key
